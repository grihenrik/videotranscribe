# YouTube Transcription Service Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================================
# REQUIRED: OpenAI API Configuration
# ===========================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ===========================================
# OPTIONAL: Whisper Model Configuration
# ===========================================
# Available models: tiny, base, small, medium, large, large-v2, large-v3
# Note: Larger models provide better accuracy but require more resources
WHISPER_MODEL=base

# ===========================================
# OPTIONAL: Proxy Configuration
# ===========================================
# If you need to bypass YouTube restrictions, configure one of these proxy services

# Option 1: Simple proxy URL
YOUTUBE_PROXY=http://your-proxy-server:port

# Option 2: Proxymesh (https://proxymesh.com)
PROXYMESH_USERNAME=your-proxymesh-username
PROXYMESH_PASSWORD=your-proxymesh-password

# Option 3: Bright Data (https://brightdata.com)
BRIGHT_DATA_USERNAME=your-brightdata-username
BRIGHT_DATA_PASSWORD=your-brightdata-password

# Option 4: Smart Proxy (https://smartproxy.com)
SMARTPROXY_USERNAME=your-smartproxy-username
SMARTPROXY_PASSWORD=your-smartproxy-password

# ===========================================
# OPTIONAL: Standard HTTP Proxy
# ===========================================
# These are automatically detected by most libraries
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# ===========================================
# OPTIONAL: Application Configuration
# ===========================================
# Cache settings (for future Redis support)
CACHE_TYPE=memory
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=86400

# Hardware acceleration (if you have GPU support)
USE_GPU=false

# ===========================================
# OPTIONAL: Development Settings
# ===========================================
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Temporary file directory
TEMP_DIR=tmp

# ===========================================
# NOTES
# ===========================================
# 1. Never commit your actual .env file to version control
# 2. The .env file should be in the same directory as main.py
# 3. Restart the server after changing environment variables
# 4. For production deployment, use your deployment platform's
#    environment variable configuration instead of .env files